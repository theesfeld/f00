root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.{md,mdx}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{asm,inc,nasm}]
indent_style = space
indent_size = 4

[*.{html,css,js}]
indent_size = 2
