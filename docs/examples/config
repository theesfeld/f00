# f00tils config — copy to ~/.config/f00/config  (or: f00-config init)
# See docs/CONFIG.md
#
# f00tils uses your terminal palette by default.
# f00-config theme list  →  f00-config theme set <name>

theme = terminal
core = false
color = auto
icons = auto      # Nerd File Icons when color on; ascii on linux console
# icons = ascii
# icons = never
# icons = nerd
animations = true
spinner = true

[ls]
git = true
icons = auto

[sha256sum]
spinner = true
