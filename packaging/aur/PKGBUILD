# Maintainer: theesfeld
pkgname=f00
pkgver=0.15.0
pkgrel=1
pkgdesc="Pure assembly GNU coreutils replacement suite (multicall, freestanding)"
arch=('x86_64')
url="https://f00.sh"
license=('MIT')
depends=()
makedepends=('nasm' 'binutils')
provides=('f00')
conflicts=('f00')
source=("https://github.com/theesfeld/f00/archive/refs/tags/v0.15.0.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/f00-0.15.0/asm" 2>/dev/null || cd "${srcdir}/f00-"*/asm
  make
}

package() {
  cd "${srcdir}/f00-0.15.0/asm" 2>/dev/null || cd "${srcdir}/f00-"*/asm
  install -Dm755 f00 "${pkgdir}/usr/bin/f00"
  local u
  for u in ls cat head tail wc true false yes id date uname md5sum sha256sum \
           cp mv rm mkdir basename dirname pwd echo env sort uniq cut tr \
           df du stat realpath readlink nproc whoami tty; do
    ln -s f00 "${pkgdir}/usr/bin/f00-${u}"
  done
  # full link set
  if [[ -f Makefile ]]; then
    # install all f00-* from make links if present
    for f in f00-*; do
      [[ -L "$f" || -f "$f" ]] || continue
      install -Dm755 f00 "${pkgdir}/usr/bin/${f}"
    done
  fi
  install -Dm644 ../LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" 2>/dev/null || true
  if [[ -d man/man1 ]]; then
    install -Dm644 man/man1/f00.1 "${pkgdir}/usr/share/man/man1/f00.1"
    install -Dm644 man/man1/f00-ls.1 "${pkgdir}/usr/share/man/man1/f00-ls.1" 2>/dev/null || true
  fi
}
